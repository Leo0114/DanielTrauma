---
import Container from "./ui/Container.astro";
import ThemeToggle from "./shared/ThemeToggle.astro";

const navLinks = [
  { label: "Inicio", href: "/" },
  { label: "Acerca del Dr.", href: "/acerca" },
  { label: "Contacto", href: "/contacto" },
];

const pathname = Astro.url.pathname;

function isActive(href: string) {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
}
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <Container>
    <nav
      class="flex items-center justify-between h-16 md:h-20"
      aria-label="Navegación principal"
    >
      <!-- Logo -->
      <a
        href="/"
        class="flex items-center gap-3 group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary rounded-lg"
        aria-label="Dr. Hernández Coronado - Inicio"
      >
        <div
          class="flex items-center justify-center w-10 h-10 rounded-xl bg-primary text-white font-display font-bold text-lg shadow-md group-hover:scale-105 transition-transform duration-200"
        >
          H
        </div>
        <div class="hidden sm:block">
          <p class="font-display font-700 text-sm text-secondary dark:text-white leading-tight">
            Dr. Hernández Coronado
          </p>
          <p class="text-xs text-text-muted font-body leading-tight">
            Traumatólogo · Ortopedista
          </p>
        </div>
      </a>

      <!-- Desktop nav links -->
      <ul class="hidden md:flex items-center gap-1" role="list">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class={`relative px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200 font-body
                  ${
                    isActive(link.href)
                      ? "text-primary"
                      : "text-text dark:text-white hover:text-primary dark:hover:text-primary"
                  }`}
                aria-current={isActive(link.href) ? "page" : undefined}
              >
                {link.label}
                {isActive(link.href) && (
                  <span class="absolute bottom-0 left-4 right-4 h-0.5 bg-primary rounded-full" />
                )}
              </a>
            </li>
          ))
        }
      </ul>

      <!-- Right actions -->
      <div class="flex items-center gap-2">
        <ThemeToggle />

        <!-- CTA Button desktop -->
        <a
          href="/contacto"
          id="navbar-cta"
          class="hidden md:inline-flex items-center gap-2 px-5 py-2.5 bg-primary hover:bg-primary-dark text-white text-sm font-semibold rounded-full transition-all duration-200 hover:-translate-y-0.5 shadow-md hover:shadow-primary font-body"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
            ></path>
          </svg>
          Agendar Consulta
        </a>

        <!-- Mobile hamburger -->
        <button
          id="mobile-menu-toggle"
          class="md:hidden flex items-center justify-center w-10 h-10 rounded-lg text-text dark:text-white hover:bg-surface dark:hover:bg-dark-surface transition-colors duration-200"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Abrir menú"
        >
          <svg
            id="hamburger-icon"
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"
            ></path>
          </svg>
          <svg
            id="close-icon"
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5 hidden"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"
            ></path>
          </svg>
        </button>
      </div>
    </nav>
  </Container>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-border dark:border-dark-border bg-white dark:bg-dark-surface"
    role="dialog"
    aria-label="Menú de navegación"
  >
    <Container>
      <ul class="py-4 space-y-1" role="list">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class={`flex items-center px-4 py-3 rounded-lg text-sm font-medium transition-all duration-200 font-body
                  ${
                    isActive(link.href)
                      ? "bg-primary/10 text-primary"
                      : "text-text dark:text-white hover:bg-surface dark:hover:bg-dark-card"
                  }`}
                aria-current={isActive(link.href) ? "page" : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
        <li class="pt-2">
          <a
            href="/contacto"
            class="flex items-center justify-center gap-2 w-full px-4 py-3 bg-primary hover:bg-primary-dark text-white text-sm font-semibold rounded-full transition-all duration-200 font-body"
          >
            Agendar Consulta
          </a>
        </li>
      </ul>
    </Container>
  </div>
</header>

<!-- Spacer para que el contenido no quede bajo el navbar fixed -->
<div class="h-16 md:h-20" aria-hidden="true"></div>

<script>
  function initNavbar() {
    const navbar = document.getElementById("navbar");
    const mobileMenuToggle = document.getElementById("mobile-menu-toggle");
    const mobileMenu = document.getElementById("mobile-menu");
    const hamburgerIcon = document.getElementById("hamburger-icon");
    const closeIcon = document.getElementById("close-icon");

    // Glassmorphism on scroll
    const handleScroll = () => {
      if (!navbar) return;
      if (window.scrollY > 20) {
        navbar.classList.add(
          "glass",
          "shadow-md",
          "dark:glass-dark",
          "border-b",
          "border-border/50"
        );
      } else {
        navbar.classList.remove(
          "glass",
          "shadow-md",
          "dark:glass-dark",
          "border-b",
          "border-border/50"
        );
      }
    };

    window.removeEventListener("scroll", handleScroll);
    window.addEventListener("scroll", handleScroll);
    handleScroll();

    // Mobile menu toggle
    mobileMenuToggle?.addEventListener("click", () => {
      const isOpen = mobileMenu?.classList.contains("hidden") === false;
      if (isOpen) {
        mobileMenu?.classList.add("hidden");
        hamburgerIcon?.classList.remove("hidden");
        closeIcon?.classList.add("hidden");
        mobileMenuToggle.setAttribute("aria-expanded", "false");
        mobileMenuToggle.setAttribute("aria-label", "Abrir menú");
      } else {
        mobileMenu?.classList.remove("hidden");
        hamburgerIcon?.classList.add("hidden");
        closeIcon?.classList.remove("hidden");
        mobileMenuToggle.setAttribute("aria-expanded", "true");
        mobileMenuToggle.setAttribute("aria-label", "Cerrar menú");
      }
    });

    // Close mobile menu on link click
    mobileMenu?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        mobileMenu.classList.add("hidden");
        hamburgerIcon?.classList.remove("hidden");
        closeIcon?.classList.add("hidden");
        mobileMenuToggle?.setAttribute("aria-expanded", "false");
      });
    });
  }

  document.addEventListener("astro:page-load", initNavbar);
</script>
