---
import Layout from "@/layouts/Layout.astro";
import { ContactHero, OfficesSection, FAQSection } from "@/components/contact/FAQSection";
import ContactForm from "@/components/contact/ContactForm";
---

<Layout
  title="Contacto y Citas — Dr. Daniel Hernández Coronado | Traumatólogo Monterrey"
  description="Agenda tu consulta con el Dr. Daniel Hernández Coronado, Traumatólogo y especialista en columna en Monterrey. Formulario inteligente con carga de estudios DICOM. Sin compromiso."
>
  <ContactHero client:load />

  <!-- Form + Info Grid -->
  <section class="py-16 md:py-24 bg-white dark:bg-dark-bg">
    <div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">
        <!-- Form column (wider) -->
        <div class="lg:col-span-3">
          <div class="mb-8">
            <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/10 dark:bg-primary/20 border border-primary/20 text-sm font-semibold text-primary font-body mb-4">
              Formulario de Consulta
            </span>
            <h2 class="font-display text-2xl sm:text-3xl font-bold text-secondary dark:text-white mb-3">
              Cuéntenos cómo podemos ayudarle
            </h2>
            <p class="text-text-muted dark:text-slate-400 font-body leading-relaxed">
              Complete el formulario y nuestro equipo le contactará en menos de 24 horas para confirmar su cita.
            </p>
          </div>
          <div class="p-7 md:p-10 rounded-3xl bg-surface dark:bg-dark-card border border-border dark:border-dark-border shadow-sm">
            <ContactForm client:load />
          </div>
        </div>

        <!-- Sidebar info -->
        <div class="lg:col-span-2 space-y-5 lg:sticky lg:top-24">
          <!-- Quick contact card -->
          <div class="p-6 rounded-2xl bg-gradient-to-br from-secondary to-primary/70 text-white">
            <h3 class="font-display font-bold text-lg mb-4">¿Prefiere contactar directamente?</h3>
            <div class="space-y-4">
              <a
                href="tel:+528180229071"
                class="flex items-center gap-3 p-3 rounded-xl bg-white/10 hover:bg-white/20 transition-colors duration-200"
                aria-label="Llamar al consultorio"
              >
                <div class="w-9 h-9 rounded-lg bg-primary/30 flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-slate-300 font-body">Llamar ahora</p>
                  <p class="text-sm font-bold">+52 81 8022 9071</p>
                </div>
              </a>

              <a
                href="https://wa.me/528180229071?text=Hola%20Dr.%20Hern%C3%A1ndez%2C%20me%20gustar%C3%ADa%20agendar%20una%20consulta."
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 p-3 rounded-xl bg-white/10 hover:bg-white/20 transition-colors duration-200"
                aria-label="Contactar por WhatsApp"
              >
                <div class="w-9 h-9 rounded-lg bg-green-500/50 flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-white" viewBox="0 0 24 24">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-slate-300 font-body">WhatsApp</p>
                  <p class="text-sm font-bold">Mensaje directo</p>
                </div>
              </a>
            </div>
          </div>

          <!-- What to expect -->
          <div class="p-6 rounded-2xl bg-surface dark:bg-dark-card border border-border dark:border-dark-border">
            <h3 class="font-display font-bold text-secondary dark:text-white mb-5">¿Qué esperar?</h3>
            <ol class="space-y-4">
              {[
                { step: "1", text: "Envíe su solicitud por el formulario o WhatsApp" },
                { step: "2", text: "Nuestro equipo le confirma fecha y hora en menos de 24h" },
                { step: "3", text: "Acuda a consulta con sus estudios previos (si los tiene)" },
                { step: "4", text: "Reciba su diagnóstico y plan de tratamiento personalizado" },
              ].map(({ step, text }) => (
                <li class="flex items-start gap-3">
                  <div class="w-7 h-7 rounded-full bg-primary/10 dark:bg-primary/20 flex items-center justify-center text-primary font-bold text-xs flex-shrink-0 mt-0.5 font-display">
                    {step}
                  </div>
                  <p class="text-sm text-text-muted dark:text-slate-400 font-body leading-relaxed">
                    {text}
                  </p>
                </li>
              ))}
            </ol>
          </div>

          <!-- Important notice -->
          <div class="p-5 rounded-2xl bg-accent/5 dark:bg-accent/10 border border-accent/20">
            <div class="flex items-start gap-3">
              <span class="text-xl flex-shrink-0" aria-hidden="true">ℹ️</span>
              <p class="text-sm text-text dark:text-slate-300 font-body leading-relaxed">
                <strong>Recuerde:</strong> Visitar al traumatólogo no implica necesariamente una cirugía. La gran mayoría de casos tienen solución conservadora.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <OfficesSection client:visible />
  <FAQSection client:visible />
</Layout>
