---
// Container.astro — Componente de ancho máximo consistente

interface Props {
  size?: "sm" | "md" | "lg" | "xl" | "2xl" | "full";
  class?: string;
  as?: "div" | "section" | "article" | "main";
}

const {
  size = "xl",
  class: className = "",
  as: Tag = "div",
} = Astro.props;

const maxWidths = {
  sm:   "max-w-2xl",
  md:   "max-w-4xl",
  lg:   "max-w-5xl",
  xl:   "max-w-7xl",
  "2xl": "max-w-screen-2xl",
  full: "max-w-full",
};
---

<Tag
  class={`mx-auto w-full px-4 sm:px-6 lg:px-8 ${maxWidths[size]} ${className}`}
>
  <slot />
</Tag>
